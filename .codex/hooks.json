{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "log-prompt",
            "command": "AI_TOOL_NAME=codex python3 scripts/python/log_hook.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "log-stop",
            "command": "AI_TOOL_NAME=codex python3 scripts/python/log_hook.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/khuym_stop.mjs",
            "statusMessage": "Khuym: end-of-turn check"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/khuym_session_start.mjs",
            "statusMessage": "Khuym: session bootstrap"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/khuym_pre_tool_use.mjs",
            "statusMessage": "Khuym: shell guardrails"
          }
        ]
      }
    ]
  }
}
