# AI providers
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_CHAT_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_ROUTER_MODEL=gemini-3-flash-preview
QDRANT_KNOWLEDGE_COLLECTION=knowledge_chunks

# OCR
USE_SMART_EXTRACTION=true
ENABLE_VISION_FALLBACK=true
OCR_PIPELINE_VERSION=v2


# Optional remote OCR parser. Leave empty to use OpenAI Vision fallback.
OCR_PARSE_API_KEY=
OCR_PARSE_API_BASE_URL=
OCR_PARSE_POLL_INTERVAL_SECONDS=2
OCR_PARSE_TIMEOUT_SECONDS=600

# Database configuration
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Qdrant API Key (for lead enrichment)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=sk...

# Cloudflare R2
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
R2_PUBLIC_BASE_URL=https://<public-domain-or-r2-dev-domain>

# jwt secret key
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Cookie configuration
# Local HTTP: false
# Production HTTPS: true
COOKIE_SECURE=false

# redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=default

# Retention jobs
MESSAGE_CHUNK_USAGE_RETENTION_ENABLED=true
MESSAGE_CHUNK_USAGE_RETENTION_DAYS=60
MESSAGE_CHUNK_USAGE_RETENTION_RUN_HOUR=3
MESSAGE_CHUNK_USAGE_RETENTION_BATCH_SIZE=1000
MESSAGE_CHUNK_USAGE_RETENTION_MAX_BATCHES=100

CHAT_QUERY_RATE_LIMIT_PER_MINUTE=12
CHAT_QUERY_RATE_LIMIT_PER_HOUR=120
CHAT_QUERY_IP_RATE_LIMIT_PER_MINUTE=30
CHAT_INIT_RATE_LIMIT_PER_MINUTE=10

# Api server configuration
API_PORT=8000

# Trusted hosts (Host header validation)
# Comma-separated list of allowed Host header values.
# Must include the Railway deployment domain.
TRUSTED_HOSTS=a20-app-165-production.up.railway.app,a20-app-165.up.railway.app,localhost,127.0.0.1

# CORS configuration
# Local example:
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://127.0.0.1:3000,https://xxx.ngrok-free.app
# Production example:
# CORS_ALLOW_ORIGINS=https://your-frontend-domain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# Telegram
# Set your bot token here (do NOT commit real tokens).
TELEGRAM_BOT_TOKEN=123456:ABCDEF_your_token_here
TELEGRAM_POLLING_ENABLED=false

# Zalo Bot (official Zalo Bot API — https://bot.zapps.me/docs)
# Create a bot via the "Zalo Bot Manager" OA in the Zalo app; the token is sent
# to you in a Zalo message. Do NOT commit real tokens.
ZALO_BOT_TOKEN=
# Enable getUpdates long-polling for local/dev. Do NOT enable when a webhook is set.
ZALO_POLLING_ENABLED=false
# Shared secret echoed back by Zalo in the X-Bot-Api-Secret-Token header
# (set it via setWebhook). 8-256 chars. Leave empty to disable verification (local only).
ZALO_WEBHOOK_SECRET=

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log


# Firecrawl
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Initial admin bootstrap on deploy
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
